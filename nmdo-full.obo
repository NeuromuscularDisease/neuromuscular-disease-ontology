synonym: "Charcot-Marie-Tooth neuropathy, type 4C" RELATED []
synonym: "CMT 4C" RELATED [GARD:0009201]
synonym: "CMT4C" EXACT ABBREVIATION [DOID:0110183, MONDO:Lexical, NCIT:C129864, OMIM:601596, Orphanet:99949]
synonym: "SH3TC2 Charcot-Marie-Tooth disease type 4" EXACT [MONDO:design_pattern, MONDO:patterns/disease_series_by_gene]
