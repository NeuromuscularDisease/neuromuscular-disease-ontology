synonym: "spinocerebellar ataxia with axonal neuropathy" RELATED [GARD:0010000]
synonym: "spinocerebellar ataxia with axonal neuropathy type 1" RELATED []
synonym: "spinocerebellar ataxia, autosomal recessive, with axonal neuropathy" BROAD []
