synonym: "muscular dystrophy, autosomal recessive, with cardiomyopathy and triangular tongue" EXACT [OMIM:616827]
synonym: "muscular dystrophy, limb-girdle, type 2W" EXACT [DOID:0110288, OMIM:616827]
synonym: "muscular dystrophy, limb-girdle, type 2w" EXACT [DOID:0110288, OMIM:616827]
