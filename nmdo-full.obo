synonym: "myopathy, myofibrillar, 4" RELATED [MONDO:Lexical]
synonym: "myopathy, myofibrillar, type 4" EXACT [MONDO:RULE_1]
synonym: "ZASP-related myofibrillar myopathy" EXACT [Orphanet:98912]
synonym: "zaspopathy" EXACT [DOID:0080095]
