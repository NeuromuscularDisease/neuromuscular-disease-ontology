synonym: "insensitivity to pain, congenital, with gastrointestinal dysfunction and hyperhidrosis" RELATED []
synonym: "neuropathy, hereditary sensory and autonomic, type 7" RELATED []
synonym: "neuropathy, hereditary sensory and autonomic, type VII" RELATED [GARD:0012732, MONDO:Lexical]
synonym: "SCN11A autosomal dominant hereditary sensory and autonomic neuropathy" EXACT [MONDO:design_pattern, MONDO:patterns/disease_series_by_gene]
